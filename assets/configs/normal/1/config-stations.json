    "en": {
        "legend": [
            {
                "infoType": "title",
                "content": "Data"
            },
            {
                "infoType": "text",
                "content":
                    "Climate normals and averages are used to summarize or describe the average climatic conditions of a particular location.\n\nAt the completion of each decade, Environment and Climate Change Canada updates its climate normals for as many locations and as many climatic characteristics as possible. The climate normals, averages and extremes offered here are based on Canadian climate stations with at least 15 years of data between 1981 to 2010."
            },
            {
                "layerId": "NORMAL_station_en",
                "layerName": "",
                "description":
                    "These are Canadian climate stations during the Normals period (1981-2010) that either have records of 25 years or better during that period, or have shorter records but are needed to represent several major centres.",
                "coverIcon": "assets/images/cities.svg",
                "symbologyStack": [
                    {
                        "image": "assets/images/blue-circle.svg",
                        "text": "Station"
                    }
                ],
                "symbologyRenderStyle": "icons"
            },
