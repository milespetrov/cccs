<?xml version="1.0" encoding="UTF-8"?> 
<configuration>
  <system.webServer>
    <httpProtocol><customHeaders>
      <add name="Access-Control-Allow-Origin" value="*" />
      <add name="Content-Security-Policy-Report-Only" value="default-src 'self' *.canada.ca *.gc.ca wet-boew.github.io; script-src 'unsafe-inline' 'unsafe-eval' 'self' *.geo.ca *.fontawesome.com *.canada.ca *.gc.ca wet-boew.github.io cdn.polyfill.io *.googleapis.com *.msecnd.net js.arcgis.com cdn.datatables.net www.googletagmanager.com www.google-analytics.com; connect-src 'self' *.canada.ca *.gc.ca dc.services.visualstudio.com; style-src 'unsafe-inline' 'self' *.canada.ca *.gc.ca wet-boew.github.io fonts.googleapis.com; img-src * data: blob:; font-src *;" />
      <add name="X-Xss-Protection" value="1; mode=block" />
      <add name="X-Content-Type-Options" value="nosniff" />
    </customHeaders></httpProtocol>
    <httpErrors errorMode="Custom" defaultResponseMode="ExecuteURL">
      <remove statusCode="404" subStatusCode="-1" /> <error statusCode="404" path="/assets/404.html" responseMode="ExecuteURL" />
    </httpErrors>
    <staticContent>
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <mimeMap fileExtension=".md" mimeType="text/markdown" />
      <mimeMap fileExtension=".download" mimeType="application/javascript" />
    </staticContent>
  </system.webServer>
</configuration> 
